# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your values

aws_region = "us-east-2"
environment = "production"
project_name = "video-processor"
cluster_name = "video-processor-cluster"

# RDS Configuration (if enabled)
enable_rds = false
rds_instance_class = "db.t3.medium"
rds_allocated_storage = 100
rds_engine_version = "15.4"
rds_database_name = "video_recall_db"
rds_username = "postgres"
rds_password = "CHANGE_THIS_PASSWORD" # Use a strong password!

# S3 Configuration
s3_bucket_name = "video-processor-mvp-storage"

# Logging
log_retention_days = 7

# ALB Configuration
enable_deletion_protection = false

