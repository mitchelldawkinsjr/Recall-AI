# ─────────────────────────────────────────────────────────────────────────────
# AskMyVideo / recall-ai — Production Environment Template
# Copy this file to .env next to docker-compose.prod.yml and fill in real values.
# The .env file must NEVER be committed to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=video_recall_project.settings.production
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

DEBUG=False

# Comma-separated: your domain + localhost for health checks
ALLOWED_HOSTS=recall.360web.cloud,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://recall.360web.cloud
CSRF_TRUSTED_ORIGINS=https://recall.360web.cloud

# ── Database (Postgres) ──────────────────────────────────────────────────────
DB_DATABASE=recall_ai
DB_USERNAME=recall
DB_PASSWORD=change-me-strong-password-here

# ── Ports ────────────────────────────────────────────────────────────────────
APP_PUBLISH_PORT=8030

# ── Gunicorn ─────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=300

# ── AI / ML (optional — leave blank to disable enhanced AI features) ─────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
HUGGINGFACE_API_KEY=

# ── Storage (optional — leave USE_S3=False to use local disk on VPS) ─────────
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# ── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Email (optional) ─────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Admin bootstrap (optional — set for first deploy only) ───────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-strong-admin-password

# ── YouTube ingestion (required on VPS for reliable YouTube URL uploads) ───────
# Netscape-format cookies.txt exported from a logged-in browser session.
# Run deploy/setup-youtube-cookies.sh once to upload cookies to the VPS.
# Place on VPS: /opt/360ws/clients/docker-app/recall-ai/secrets/youtube_cookies.txt
YOUTUBE_COOKIES_FILE=/app/secrets/youtube_cookies.txt

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
